# Primary LLM Provider (recommended - highest rate limits)
NVIDIA_API_KEY=nvapi-your_nvidia_key_here

# Fallback Providers (uncomment to use)
# GROQ_API_KEY=gsk_your_groq_key_here
# GOOGLE_API_KEY=your_gemini_key_here

# Database (SQLite by default, switch to PostgreSQL for production)
DATABASE_URL=sqlite:///./hcp_crm.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/hcp_crm
